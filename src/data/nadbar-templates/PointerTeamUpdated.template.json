        },
        {
          "source": "They",
          "content": "קבל למטרה {{metara}} חיובי בגובה {{obstacleHeight1}} במרחק {{obstacleDistance1}}",
          "visibleWhen": { "var": "hasNearbyObstacles", "equals": "חיובי" }
        },
        {
          "source": "Me",
          "content": "קיבלתי למטרה {{metara}} חיובי בגובה {{obstacleHeight1}} במרחק {{obstacleDistance1}}",
