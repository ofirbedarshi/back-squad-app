      "messages": [
        {
          "source": "Me",
          "content": "למטרה {{metara}}, האם יש הסתרים קרובים באיזור המטרה? {{hasNearbyObstacles}}"
        },
        {
          "source": "They",
          "content": "קבל למטרה {{metara}} שלילי",
          "visibleWhen": { "var": "hasNearbyObstacles", "equals": "שלילי" }
        },
        {
          "source": "Me",
