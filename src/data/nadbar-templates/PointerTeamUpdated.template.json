        {
          "source": "They",
          "content": "קבל מטרה {{metara}}, מרעום {{meraom}}"
        },
        {
          "source": "Me",
          "content": "קיבלתי מטרה {{metara}}, מרעום {{meraom}}"
        },
        {
          "source": "They",
          "content": "קבל צפע {{tsepa}}"
        },
        {
          "source": "Me",
          "content": "קיבלתי צפע {{tsepa}}"
        },
        {
          "source": "They",
          "content": "קבל גמל {{gamal}}"
        },
        {
          "source": "Me",
          "content": "קיבלתי גמל {{gamal}}"
        }
      ]
    },
    {
      "footerActions": ["loadTarget"],
      "messages": [
        {
          "source": "They",
          "content": "{{openingCallsign1}} מ {{openingCallsign2}} קבל למטרה {{metara}} אמורה {{amura}} במעלות"
        },
        {
          "source": "Me",
          "content": "קיבלתי למטרה {{metara}} אמורה {{amura}} במעלות"
        },
        {
          "source": "They",
          "content": "קבל למטרה {{metara}} אמורה {{amuraValid}}"
        },
        {
          "source": "They",
          "content": "שפר ל {{amuraCorrected}} במעלות",
          "visibleWhen": { "var": "amuraValid", "equals": "לא תקינה" }
        },
        {
          "source": "Me",
          "content": "קיבלתי, למטרה {{metara}} שפרתי ל {{amuraCorrected}} במעלות",
          "visibleWhen": { "var": "amuraValid", "equals": "לא תקינה" }
        }
      ]
    },
    {
