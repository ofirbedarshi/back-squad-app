        },
        {
          "source": "They",
          "content": "כמו כן הסתר נוסף בגובה {{obstacleHeight2}} במרחק {{obstacleDistance2}}",
          "visibleWhen": { "var": "obstacleActive2", "equals": "1" }
        },
        {
          "source": "Me",
          "content": "קיבלתי, הסתר נוסף בגובה {{obstacleHeight2}} במרחק {{obstacleDistance2}}",
          "visibleWhen": { "var": "obstacleActive2", "equals": "1" }
        },
        {
          "source": "They",
          "content": "כמו כן הסתר נוסף בגובה {{obstacleHeight3}} במרחק {{obstacleDistance3}}",
          "visibleWhen": { "var": "obstacleActive3", "equals": "1" }
        },
        {
          "source": "Me",
          "content": "קיבלתי, הסתר נוסף בגובה {{obstacleHeight3}} במרחק {{obstacleDistance3}}",
          "visibleWhen": { "var": "obstacleActive3", "equals": "1" }
        }
      ]
    }
  ]
